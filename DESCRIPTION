Package: RCamelsPE
Type: Package
Title: Access, Process, and Visualize CAMELS-PE Data
Version: 1.0.0
Authors@R: 
    person(
        given = "Harold",
        family = "Llauca",
        role = c("aut", "cre"),
        email = "hllauca@senamhi.gob.pe"
